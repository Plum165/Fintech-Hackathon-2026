# =============================================================================
# PandaPay Consolidated API Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then start the server:
#   npm run dev
# =============================================================================


# -----------------------------------------------------------------------------
# Open Payments / Interledger  (leave blank to run in SIMULATION mode)
# -----------------------------------------------------------------------------
#
# To use REAL ILP payments you need three things from the Interledger test wallet:
#
#  STEP 1 — Create a wallet
#            Go to https://wallet.interledger-test.dev, sign up, and create a
#            wallet with a username (e.g. "pandapay").
#
#  STEP 2 — Generate a key pair
#            Settings → Developer Keys → "Add public key" → "Generate key pair"
#            The wallet keeps your public key and lets you download the private key.
#
#  STEP 3 — Save the private key
#            Rename the downloaded file to  private.key  and put it in THIS
#            directory (src/server/private.key).
#            See  private.key.example  in this folder for the expected format.
#
#  STEP 4 — Copy the Key ID
#            After generating, the dashboard shows a Key ID (a UUID).
#            Paste it as KEY_ID below.
#
#  STEP 5 — Set your wallet address
#            Format is:  https://ilp.interledger-test.dev/<your-username>

SERVER_WALLET_ADDRESS=https://ilp.interledger-test.dev/pandapay
KEY_ID=YOUR_KEY_ID_HERE

# Path to your private key PEM file (relative to this directory).
# Default: ./private.key  (i.e. src/server/private.key)
PRIVATE_KEY_PATH=./private.key


# -----------------------------------------------------------------------------
# AI Integration  (optional — enables auto-categorisation and chat advice)
# -----------------------------------------------------------------------------
# Set AI_PROVIDER to whichever service you have a key for.
# Options: gemini | openai | grok

AI_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# CORS — extra origins to allow in addition to localhost:3000/5173/5174/5689.
# Add your Vercel deployment URLs here (comma-separated) if they don't end in
# .vercel.app (custom domains).  Wildcard .vercel.app and .trycloudflare.com
# are already allowed automatically.
# ALLOWED_ORIGINS=https://zen-i.yourdomain.com,https://merchant.yourdomain.com
