# ============================================================
# PandaPay Consolidated API Server - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.

# --------------------------------------------------
# Open Payments / Interledger (REQUIRED for real ILP)
# --------------------------------------------------
# Create a test wallet at https://wallet.interledger-test.dev
# Register a key pair, download the private key, and fill in below.

# Your PandaPay platform wallet address (the server's own wallet)
SERVER_WALLET_ADDRESS=https://ilp.interledger-test.dev/pandapay

# The key ID registered on your wallet (shown in the wallet dashboard)
KEY_ID=YOUR_KEY_ID_HERE

# Path to the private key PEM file you downloaded
PRIVATE_KEY_PATH=./private.key

# --------------------------------------------------
# AI Integration (optional - auto-categorization)
# --------------------------------------------------
# Set to: gemini | openai | grok
AI_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE

# --------------------------------------------------
# Server
# --------------------------------------------------
PORT=4000
NODE_ENV=development
