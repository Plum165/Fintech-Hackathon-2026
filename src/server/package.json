{
  "name": "pandapay-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch index.ts",
    "build": "esbuild index.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/index.cjs",
    "start": "node dist/index.cjs"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@interledger/open-payments": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
