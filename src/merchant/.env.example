# =============================================================================
# Merchant Frontend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Then start (after starting src/server first):
#   npm run dev

# Port this frontend dev server listens on (default: 5689)
PORT=5689

# URL of the consolidated API server.
# Dev: leave this blank — the Vite proxy handles /api/* → localhost:4000
# Production (Vercel): set to your Cloudflare tunnel URL, e.g.
#   API_URL=https://abc123.trycloudflare.com   ← for the Node server.ts proxy
API_URL=http://localhost:4000

# VITE_API_URL — picked up at Vite build time (only set for Vercel deployments).
# In the Vercel dashboard: Settings → Environment Variables → add VITE_API_URL.
# Leave blank for local dev.
# VITE_API_URL=https://abc123.trycloudflare.com
